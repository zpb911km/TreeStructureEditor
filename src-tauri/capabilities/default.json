{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-write",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-create",
    "fs:allow-remove",
    "fs:allow-exists",
    "fs:allow-rename",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$HOME"
        },
        {
          "path": "$HOME/**/*"
        },
        {
          "path": "$DOCUMENT"
        },
        {
          "path": "$DOCUMENT/**/*"
        },
        {
          "path": "$APPLOCALDATA"
        },
        {
          "path": "$APPLOCALDATA/**/*"
        }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*/*" },
        { "url": "http://*/*" }
      ]
    }
  ]
}