{
  "name": "tree-structure-editor",
  "version": "1.0.0",
  "description": "A tree-based markdown editor built with Tauri and Vue 3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:windows": "tauri build --target x86_64-pc-windows-gnu",
    "format": "prettier --write ./src ./src-tauri/src",
    "format:check": "prettier --check ./src ./src-tauri/src"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-fs": "~2.4.5",
    "katex": "^0.16.11",
    "marked": "^15.0.6",
    "monaco-editor": "^0.55.1",
    "prettier": "^3.7.4",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.7",
    "@types/katex": "^0.16.7",
    "@types/marked": "^5.0.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  },
  "keywords": [
    "tauri",
    "vue",
    "markdown",
    "tree",
    "editor"
  ],
  "author": "zpb911km",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1"
}